# Environment variables for the Treehouse site.
# Copy to `.env` for local use, and set these in the Railway dashboard for prod.
# `.env` is gitignored — never commit real secrets.

# REQUIRED in production (DEBUG off). Generate a fresh one, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-freshly-generated-secret

# Local development only — enables DEBUG. Leave UNSET (or 0) in production.
# DJANGO_DEBUG=1

# Optional: comma-separated allowed hosts. Defaults already cover
# skfarhad.com, *.railway.app, and localhost — override only if needed.
# DJANGO_ALLOWED_HOSTS=skfarhad.com,www.skfarhad.com
